package ui

import "github.com/Francesco99975/authpoc/views/icons"

templ SubmitButton(id string) {
	<div class="relative">
		<button
			type="submit"
			class="w-full py-3 md:py-3.5 bg-primary text-white font-semibold rounded-xl hover:bg-primary/90 hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0 transition-all duration-200 disabled:opacity-75 disabled:cursor-not-allowed"
		>
			{ children... }
		</button>
		<div id={ id } class="htmx-indicator absolute inset-0 flex items-center justify-center bg-primary/95 rounded-xl pointer-events-none">
			@icons.Loading("w-5 h-5 animate-spin text-white")
		</div>
	</div>
}

templ LoadingIndicator(id string) {
	<div id={ id } class="htmx-indicator absolute inset-0 flex items-center justify-center pointer-events-none">
		@icons.Loading("w-5 h-5 animate-spin text-white")
	</div>
}
